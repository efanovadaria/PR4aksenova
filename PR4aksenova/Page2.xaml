<Page x:Class="PR4aksenova.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Page2" Height="548">

    <ScrollViewer>
        <Grid Margin="20" Height="511">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="66.08"/>
                <RowDefinition Height="23.8"/>
                <RowDefinition Height="7.58"/>
                <RowDefinition Height="17.4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Картинка формулы -->
            <Image Grid.Row="0"
                   Height="120"
                   Margin="0,0,0,20"
                   Source="C:\Users\Huawei\source\repos\PR4aksenova\PR4aksenova\Images\formula2.png"/>

            <!-- Ввод X -->
            <Label Content="Введите X:" Margin="0,114,0,0"/>
            <TextBox x:Name="txtX"
                     Grid.Row="2"
                     Margin="0,0,0,15"/>

            <Label Content="Введите Y:" Margin="0,26,0,56" Grid.RowSpan="3" Grid.Row="2"/>
            <TextBox x:Name="txtY"
         Margin="0,15,0,33" Grid.Row="4"/>

            <!-- Выбор функции -->
            <Label Grid.Row="4"
                   Content="Выберите функцию f(x):"
                   FontWeight="Bold"
                   Margin="0,33,0,7"/>

            <StackPanel Grid.Row="5" Margin="0,7,0,-8" Grid.RowSpan="4">

                <RadioButton x:Name="rbSinh"
                             Content="sh(x)"
                             GroupName="functions"
                             Margin="5"/>

                <RadioButton x:Name="rbSquare"
                             Content="x²"
                             GroupName="functions"
                             Margin="5"/>

                <RadioButton x:Name="rbExp"
                             Content="eˣ"
                             GroupName="functions"
                             Margin="5"/>
            </StackPanel>

            <!-- Результат -->
            <Label Grid.Row="8" Content="Результат:" Margin="0,24,0,-25"/>
            <TextBox x:Name="txtResult"
                     Grid.Row="8"
                     IsReadOnly="True"
                     Margin="0,55,0,-60"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,116,0,-121">

                <Button Content="Вычислить"
                        Width="100"
                        Margin="5"
                        Click="BtnCalculate_Click"/>

                <Button Content="Очистить"
                        Width="100"
                        Margin="5"
                        Click="BtnClear_Click"/>

                <Button Content="Далее"
                        Width="100"
                        Margin="5"
                        Click="BtnNext_Click"/>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>